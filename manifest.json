{
  "manifest_version": 3,
  "name": "Better Rhythia Downloader",
  "version": "1.0.0",
  "description": "Adds direct download buttons to Rhythia map cards.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.rhythia.com/maps*",
        "https://rhythia.com/maps*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://production.rhythia.com/*"
  ]
}
